# Read by docker-compose at `up` time. Each variable here is interpolated
# into docker-compose.yml. Override per-device by editing this file (it
# lives in the plugin's install dir on the host) before plugin restart.

# Hardware platform string for RKLLM init.
TARGET_PLATFORM=rk3588

# Container image tag. Default `release` (production builds, once the
# publish workflow in functionland/blox-ai gains a release tag). The lab
# overrides this to `test` for canary testing — see operator docs.
# Available tags published by functionland/blox-ai's CI:
#   - main: tracks the main branch tip (every push)
#   - test: alias for main (every push to main)
#   - vX.Y.Z: published on git tag pushes
#   - release: TODO — add to publish workflow once first stable build is cut
BLOX_AI_IMAGE_TAG=release

# Path the container reads (BLOX_AI_MODEL_PATH is what src/runtime/rkllm_runtime.py
# checks at init; the previous name RKLLM_MODEL_PATH was unread dead code).
# Inside the container, /uniondrive maps to host's /uniondrive/blox-ai (per
# the docker-compose.yml volume mount), so the in-container path is
# /uniondrive/model/<model.rkllm> not /uniondrive/blox-ai/model/<model.rkllm>.
BLOX_AI_MODEL_PATH=/uniondrive/model/qwen2.5-3b-instruct-rk3588-w8a8.rkllm
